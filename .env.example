# ============================================================
# Fund Research Platform — 环境变量配置模板
# 复制此文件为 .env 并根据本地环境修改
# .env 文件不会被提交到 git 仓库
# ============================================================

# --- 数据存储 ---
# 数据库路径（默认使用 DuckDB）
FUND_DB_PATH=./data/fund_research.duckdb
# 数据缓存目录
FUND_CACHE_DIR=./data/cache
# 默认样本基金列表路径
FUND_SAMPLE_FUNDS_PATH=./data/samples/sample_funds_v0.1.csv

# --- 日志 ---
FUND_LOG_LEVEL=INFO
FUND_LOG_FILE=./logs/fund_research.log

# --- Web API ---
FUND_API_HOST=127.0.0.1
FUND_API_PORT=8000
FUND_API_RELOAD=true

# --- 任务调度 ---
FUND_TASK_MAX_WORKERS=2

# --- 数据源（可选密钥） ---
# Tushare Token（如需使用 Tushare 数据源）
# FUND_TUSHARE_TOKEN=your_token_here
# 外部数据源请求超时（秒）
FUND_SOURCE_TIMEOUT_SECONDS=20
# 外部数据源失败重试次数
FUND_SOURCE_RETRY_COUNT=2

# --- 免责声明（在生成的研究包和页面中展示） ---
FUND_DISCLAIMER=本平台所有算法结果仅用于个人研究和方法验证，不构成投资建议。
