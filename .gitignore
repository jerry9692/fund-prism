# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
node_modules/

# Virtual environments
.venv/
venv/
env/

# IDE
.idea/
.vscode/
.claude/
.trae-html-share-packages/
*.swp
*.swo

# Environment files
.env
.env.local

# Database files
*.db
*.db.wal
*.duckdb
*.duckdb.wal
*.sqlite
*.sqlite-wal
*.sqlite-shm
*.sqlite3
*.sqlite3-wal
*.sqlite3-shm
data/cache/*
!data/cache/.gitkeep

# Notebook outputs
.ipynb_checkpoints/
*.ipynb_checkpoints

# Test coverage
htmlcov/
.coverage
.coverage.*
*.lcov
coverage.xml
.pytest_cache/
.pytest_tmp/

# MyPy
.mypy_cache/
.dmypy.json
dmypy.json

# Ruff
.ruff_cache/

# OS
.DS_Store
Thumbs.db
# Windows reserved device names that tools sometimes create as stray files
nul

# Logs
logs/
*.log

# Temporary files
tmp/
temp/
*.tmp

# User data (never commit)
data/raw/
data/external/
data/local/

# Frontend build output (dev 环境用 Vite dev server，dist 会导致后端 catch-all 覆盖 API 路由)
frontend/dist/
